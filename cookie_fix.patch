# 替换为：
        # 使用Cookie - 使用正确的Netscape cookie格式
        if cookie_str:
            cookie_file = temp_dir / "bilibili_cookie.txt"
            # 使用Netscape cookie格式，这是you-get要求的格式
            cookie_lines = []
            for item in cookie_str.split('; '):
                if '=' in item:
                    key, value = item.split('=', 1)
                    cookie_lines.append(f".bilibili.com\tTRUE\t/\tFALSE\t0\t{key}\t{value}")
            cookie_content = "# Netscape HTTP Cookie File\n" + "\n".join(cookie_lines) + "\n"
            with open(cookie_file, 'w', encoding='utf-8') as f:
                f.write(cookie_content)
            cmd.extend(['--cookies', str(cookie_file)])
            self.log_message("✓ 使用B站Cookie进行下载")